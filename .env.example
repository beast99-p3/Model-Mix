# You can keep ALL of the below filled in at once. Each feature picks its provider
# via CHAT_PROVIDER / RESUME_* / CHAIR_* / DEBATER_* (see README).

# --- OpenAI (direct API) ---
OPENAI_API_KEY=

# --- Anthropic (direct API; not the same as Bedrock) ---
ANTHROPIC_API_KEY=

# --- Amazon Bedrock ---
#
# Option A — Bedrock API key (console: long-term key). SDK reads AWS_BEARER_TOKEN_BEDROCK.
# https://docs.aws.amazon.com/bedrock/latest/userguide/api-keys-use.html
#
AWS_BEARER_TOKEN_BEDROCK=
#
# Option B — Standard AWS credential chain (IAM access keys AKIA..., or STS, or SSO):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1
# AWS_REGION=us-east-1
#
# Option C — ~/.aws profile:
# AWS_PROFILE=default
#
# Enable Bedrock for chat (example model — enable access in Bedrock console for your region):
# CHAT_PROVIDER=bedrock
# CHAT_MODEL=anthropic.claude-3-5-haiku-20241022-v1:0

# Fusion panel: four seats + one chair.
# DEBATER_AURORA_PROVIDER=bedrock
# DEBATER_AURORA_MODEL=deepseek.v3.2
# DEBATER_QUARTZ_PROVIDER=bedrock
# DEBATER_QUARTZ_MODEL=google.gemma-3-12b-it
# DEBATER_NOVA_PROVIDER=bedrock
# DEBATER_NOVA_MODEL=openai.gpt-oss-safeguard-120b
# DEBATER_LYRIC_PROVIDER=bedrock
# DEBATER_LYRIC_MODEL=us.anthropic.claude-sonnet-4-6
# CHAIR_PROVIDER=bedrock
# CHAIR_MODEL=openai.gpt-oss-safeguard-120b

# Optional: SQLite + file storage root (default: ./data)
# DATA_DIR=

# Chat / resume / chair overrides — see src/config.py
# CHAT_PROVIDER=openai
# CHAT_MODEL=gpt-4o-mini
# RESUME_DRAFT_MODEL=gpt-4o
# CHAIR_MODEL=gpt-4o
